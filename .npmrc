# GitHub Packages auth for the @nehoupat scope.
#
# This file is committed because it has to exist in the repo before
# Cloudflare Workers Builds (or wrangler in CI) installs dependencies.
# It contains no secret - the token comes from the NPM_TOKEN env var
# at install time:
#
#   - Web deploy: CF Workers Builds > Settings > Build variables, NPM_TOKEN
#     (Encrypted), value = your dearmarc PAT.
#   - Terminal deploy: export NPM_TOKEN=ghp_xxxxxxxxxxxxx before npm install.
#
# Never replace ${NPM_TOKEN} below with the literal token.

@nehoupat:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}
